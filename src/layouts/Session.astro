---
import Base from './Base.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import SessionNav from '@/components/SessionNav.astro';
import BeginnerExplainer from '@/components/BeginnerExplainer.astro';
import AdSlot from '@/components/AdSlot.astro';
import ProgressTracker from '@/components/ProgressTracker.astro';
import CodeWalkthrough from '@/components/CodeWalkthrough';
import AgentFlowDiagram from '@/components/AgentFlowDiagram';
import { createHighlighter, createCssVariablesTheme } from 'shiki';

const cssVarsTheme = createCssVariablesTheme();
import Challenge from '@/components/Challenge.astro';
import MultiTierChallenge from '@/components/MultiTierChallenge.astro';
import ReadingProgress from '@/components/ReadingProgress.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import { getLangFromUrl, getUI } from '@/i18n/ui';
import type { SessionMeta } from '@/lib/sessions';
import { getAdjacentSessions } from '@/lib/sessions';

interface Props {
  session: SessionMeta;
  frontmatter: {
    beginnerConcepts?: { question: string; answer: string }[];
    walkthroughs?: {
      title: string;
      code: string;
      language: string;
      steps: { lines: [number, number]; annotation: string }[];
    }[];
    challenge?: { text: string; hint?: string };
    challenges?: { tier: 'warmup' | 'build' | 'stretch'; text: string; hint?: string }[];
    prerequisites?: string[];
    whatYouBuild?: string;
    diagram?: {
      title: string;
      nodes: { id: string; label: string; x: number; y: number; type?: string }[];
      edges: { from: string; to: string; label?: string; animated?: boolean }[];
      steps: { title: string; description: string; activeNodes: string[]; activeEdges: number[] }[];
    };
  };
}

const { session, frontmatter } = Astro.props;
const locale = getLangFromUrl(Astro.url);
const ui = getUI(locale);
const title = locale === 'he' ? session.titleHe : session.title;
const motto = locale === 'he' ? session.mottoHe : session.motto;
const { prev, next } = getAdjacentSessions(session.slug);
const phaseKey = `phase.${session.phase}` as const;
const phaseLabel = ui[phaseKey];
const issueUrl = `https://github.com/liorp/agent-course/issues/new?title=${encodeURIComponent(`[${session.id}] `)}&body=${encodeURIComponent(`**Session:** ${session.id} — ${session.title}\n**URL:** /${locale}/${session.slug}\n\n**Describe the issue:**\n\n`)}&labels=fix`;
const isRtl = locale === 'he';
const reportArrow = isRtl ? '←' : '→';

// Pre-highlight walkthrough code with Shiki at build time
let highlightedWalkthroughs: Array<{
  title: string;
  code: string;
  language: string;
  steps: { lines: [number, number]; annotation: string }[];
  highlightedLines: string[];
}> = [];

if (frontmatter.walkthroughs && frontmatter.walkthroughs.length > 0) {
  const langs = [...new Set(frontmatter.walkthroughs.map((w: any) => w.language))];
  const highlighter = await createHighlighter({
    themes: [cssVarsTheme],
    langs: langs as string[],
  });

  highlightedWalkthroughs = frontmatter.walkthroughs.map((wt: any) => {
    const html = highlighter.codeToHtml(wt.code, {
      lang: wt.language,
      theme: cssVarsTheme.name,
    });
    // Extract inner HTML of each <span class="line"> element
    const lineRegex = /<span class="line">(.*?)<\/span>/g;
    const lines: string[] = [];
    let match;
    while ((match = lineRegex.exec(html)) !== null) {
      lines.push(match[1]);
    }
    return { ...wt, highlightedLines: lines };
  });
}
---

<Base title={title}>
  <Header />
  <ReadingProgress />
  <main class="session-page">
    <div class="session-layout container">
      <article class="session-content">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href={`/${locale}/`}>{ui['nav.sessions']}</a>
          <span class="breadcrumb-sep">&rsaquo;</span>
          <span>{phaseLabel}</span>
          <span class="breadcrumb-sep">&rsaquo;</span>
          <span>{session.order}. {title}</span>
        </nav>

        <header class="session-header">
          <h1>{session.order}. {title}</h1>
          <p class="session-motto">"{motto}"</p>
          <div class="session-meta">
            <span class="meta-time">{session.readingTime} {ui['session.readingTime']}</span>
          </div>
        </header>

        {frontmatter.prerequisites && frontmatter.prerequisites.length > 0 && (
          <div class="session-prerequisites">
            <span class="prereq-label">{ui['session.prerequisites']}:</span>
            {frontmatter.prerequisites.map((slug: string) => {
              const name = slug.replace(/^s\d+-/, '').replace(/-/g, ' ');
              return <a href={`/${locale}/${slug}`} class="prereq-link">{name}</a>;
            })}
          </div>
        )}

        {frontmatter.whatYouBuild && (
          <div class="session-what-you-build">
            <span class="wyb-label">{ui['session.whatYouBuild']}:</span>
            <span class="wyb-text">{frontmatter.whatYouBuild}</span>
          </div>
        )}

        {frontmatter.beginnerConcepts && (
          <BeginnerExplainer concepts={frontmatter.beginnerConcepts} />
        )}

        <div class="prose">
          <slot />
        </div>

        {highlightedWalkthroughs.length > 0 && (
          <section class="walkthroughs">
            <h2>{ui['session.walkthrough']}</h2>
            {highlightedWalkthroughs.map((wt) => (
              <CodeWalkthrough
                client:visible
                code={wt.code}
                language={wt.language}
                steps={wt.steps}
                title={wt.title}
                highlightedLines={wt.highlightedLines}
                isRtl={isRtl}
                labelPrev={ui['walkthrough.prev']}
                labelNext={ui['walkthrough.next']}
                labelStep={ui['walkthrough.step']}
                labelOf={ui['walkthrough.of']}
              />
            ))}
          </section>
        )}

        {frontmatter.diagram && (
          <section class="diagram-section">
            <AgentFlowDiagram
              client:visible
              nodes={frontmatter.diagram.nodes}
              edges={frontmatter.diagram.edges}
              steps={frontmatter.diagram.steps}
              title={frontmatter.diagram.title}
              isRtl={isRtl}
              labelPrev={ui['walkthrough.prev']}
              labelNext={ui['walkthrough.next']}
              labelStep={ui['walkthrough.step']}
              labelOf={ui['walkthrough.of']}
            />
          </section>
        )}

        {frontmatter.challenges && frontmatter.challenges.length > 0 ? (
          <MultiTierChallenge challenges={frontmatter.challenges} />
        ) : frontmatter.challenge ? (
          <Challenge text={frontmatter.challenge.text} hint={frontmatter.challenge.hint} />
        ) : null}

        <ProgressTracker sessionId={session.id} />

        <a href={issueUrl} target="_blank" rel="noopener" class="report-link">
          {ui['session.reportIssue']} {reportArrow}
        </a>

        <SessionNav prev={prev} next={next} />
      </article>

      <aside class="session-sidebar">
        <TableOfContents />
        <AdSlot format="sidebar" slot="4632823302" />
      </aside>
    </div>
  </main>
  <Footer />
</Base>

<style>
  .session-page { padding-block-start: 4rem; }
  .session-layout {
    display: flex;
    gap: 2rem;
    max-width: calc(var(--max-width) + var(--sidebar-width) + 2rem);
  }
  .session-content { flex: 1; min-width: 0; max-width: var(--max-width); }
  .session-sidebar { flex-shrink: 0; width: var(--sidebar-width); }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-block-end: 1.5rem;
  }
  .breadcrumb a { color: var(--accent); }
  .breadcrumb-sep { opacity: 0.5; }
  .session-header { margin-block-end: 2rem; }
  .session-motto {
    color: var(--accent);
    font-style: italic;
    font-size: 1.1rem;
    margin-block-start: 0.25rem;
  }
  .session-meta { margin-block-start: 0.75rem; }
  .meta-time { color: var(--text-muted); font-size: 0.8rem; }
  .prose { line-height: 1.75; }
  .prose h2 { margin-block-start: 2.5rem; }
  .prose h3 { margin-block-start: 2rem; }

  .report-link {
    display: inline-block;
    color: var(--text-muted);
    font-size: 0.8rem;
    opacity: 0.7;
    transition: opacity 0.2s;
  }
  .report-link:hover {
    opacity: 1;
    color: var(--accent);
  }

  .session-prerequisites {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-block-end: 0.75rem;
    font-size: 0.8rem;
  }
  .prereq-label {
    color: var(--text-muted);
    font-weight: 600;
  }
  .prereq-link {
    color: var(--accent);
    background: rgba(255, 204, 0, 0.08);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    text-transform: capitalize;
  }
  .prereq-link:hover {
    background: rgba(255, 204, 0, 0.15);
  }

  .session-what-you-build {
    background: linear-gradient(135deg, rgba(96, 165, 250, 0.06), rgba(96, 165, 250, 0.02));
    border: 1px solid rgba(96, 165, 250, 0.15);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    margin-block-end: 1.5rem;
    font-size: 0.85rem;
    line-height: 1.5;
  }
  .wyb-label {
    color: #60a5fa;
    font-weight: 600;
    margin-inline-end: 0.35rem;
  }
  .wyb-text { color: var(--text-body); }

  @media (max-width: 1024px) {
    .session-sidebar { display: none; }
    .session-layout { max-width: var(--max-width); }
  }
</style>

<script>
  // Copy-to-clipboard for code blocks
  document.querySelectorAll('.prose pre').forEach(pre => {
    const btn = document.createElement('button');
    btn.className = 'copy-code-btn';
    btn.textContent = 'Copy';
    btn.addEventListener('click', async () => {
      const code = pre.querySelector('code')?.textContent || pre.textContent || '';
      await navigator.clipboard.writeText(code);
      btn.textContent = 'Copied!';
      btn.classList.add('copied');
      setTimeout(() => {
        btn.textContent = 'Copy';
        btn.classList.remove('copied');
      }, 2000);
    });
    pre.style.position = 'relative';
    pre.appendChild(btn);
  });
</script>

<style is:global>
  .copy-code-btn {
    position: absolute;
    top: 0.5rem;
    inset-inline-end: 0.5rem;
    background: var(--bg-card, #161b35);
    color: var(--text-muted, #a0a0cc);
    border: 1px solid var(--border, #333366);
    border-radius: 4px;
    padding: 0.2rem 0.5rem;
    font-size: 0.7rem;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.2s, background 0.2s;
    font-family: inherit;
    z-index: 5;
  }
  pre:hover .copy-code-btn { opacity: 1; }
  .copy-code-btn:hover {
    background: var(--accent, #ffcc00);
    color: var(--bg-primary, #0f0f23);
    border-color: var(--accent, #ffcc00);
  }
  .copy-code-btn.copied {
    background: #4ade80;
    color: #000;
    border-color: #4ade80;
    opacity: 1;
  }
</style>
