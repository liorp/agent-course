---
import Base from '@/layouts/Base.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { getUI } from '@/i18n/ui';

const ui = getUI('he');

const terms = [
  { term: 'Agent Loop — לולאת סוכן', definition: 'לולאת ה-while-true המרכזית ששולחת הודעות ל-LLM, בודקת אם הוא רוצה להשתמש בכלים, מריצה אותם, ומזינה תוצאות בחזרה.', session: 's01' },
  { term: 'Harness — רתמה', definition: 'הקוד שעוטף את ה-LLM — הרצת כלים, ניהול הקשר, בדיקות בטיחות. המודל מחליט; הרתמה מבצעת.', session: 's01' },
  { term: 'Tool Schema — סכמת כלי', definition: 'אובייקט JSON שמתאר שם כלי, תיאור ופרמטרי קלט. ה-LLM קורא סכמות כדי להחליט באיזה כלי להשתמש.', session: 's02' },
  { term: 'Dispatch Map — מפת שיגור', definition: 'מילון שממפה שמות כלים לפונקציות handler. חיפוש אחד מחליף שרשרת if/elif.', session: 's02' },
  { term: 'TodoManager — מנהל משימות', definition: 'כלי תכנון שעוקב אחר משימות עם סטטוסים. אוכף מיקוד של משימה אחת בכל פעם.', session: 's03' },
  { term: 'Subagent — תת-סוכן', definition: 'סוכן ילד חד-פעמי שנוצר עם הקשר נקי למשימה בודדת. מחזיר סיכום ונעלם.', session: 's04' },
  { term: 'Context Compaction — דחיסת הקשר', definition: 'דחיסה הדרגתית של היסטוריית שיחה. מיקרו: קיצוץ תוצאות ישנות. בינוני: סיכום ב-50k. קשה: סיכום LLM ב-80k.', session: 's06' },
  { term: 'Task Graph — גרף משימות', definition: 'גרף מכוון ללא מעגלים של משימות עם תלויות. נשמר כקבצי JSON על הדיסק.', session: 's07' },
  { term: 'Agent Mailbox — תיבת דואר סוכן', definition: 'קובץ JSONL להוספה בלבד לתקשורת בין סוכנים. כתיבה בהוספה; קריאה בריקון.', session: 's09' },
  { term: 'Worktree — עץ עבודה', definition: 'תיקיית עבודה נפרדת של git המקושרת לאותו מאגר. כל worktree על ענף משלו לבידוד.', session: 's12' },
  { term: 'Eval Case — מקרה הערכה', definition: 'תרחיש בדיקה מובנה לסוכן: פרומפט, מגבלות משאבים, ופונקציית בדיקה שמדרגת את התוצאה.', session: 's13' },
  { term: 'Guardrail — מעקה בטיחות', definition: 'שכבת הרשאות שבודקת כל קריאת כלי לפני ביצוע. יכולה לאשר אוטומטית, לדרוש אישור אנושי, או לדחות.', session: 's14' },
  { term: 'Agent Trace — מעקב סוכן', definition: 'הקלטת JSONL של כל אירוע בסשן סוכן: קריאות LLM, הרצות כלים, שגיאות. הקופסה השחורה לדיבאג.', session: 's15' },
  { term: 'Model Routing — ניתוב מודלים', definition: 'שימוש במודלים שונים למשימות שונות: מודלים זולים להחלטות פשוטות, מודלים חזקים לחשיבה מורכבת.', session: 's16' },
];
---

<Base title={ui['session.glossary']}>
  <Header />
  <main class="session-page glossary-page">
    <div class="container" style="max-width: var(--max-width);">
      <h1 style="margin-block-end: 0.5rem;">{ui['session.glossary']}</h1>
      <p style="color: var(--text-muted); margin-block-end: 2rem; font-size: 0.9rem;">
        מונחים ומושגי מפתח מקורס הנדסת רתמה לסוכנים, לפי סדר הופעה.
      </p>
      <div class="glossary-grid">
        {terms.map(t => (
          <div class="glossary-term">
            <h3>
              {t.term}
              <span class="glossary-session">{t.session}</span>
            </h3>
            <p>{t.definition}</p>
          </div>
        ))}
      </div>
    </div>
  </main>
  <Footer />
</Base>
