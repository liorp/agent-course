---
import Base from '@/layouts/Base.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { getUI } from '@/i18n/ui';

const ui = getUI('en');

const terms = [
  { term: 'Agent Loop', definition: 'The core while-true loop that sends messages to the LLM, checks if it wants to use tools, executes them, and feeds results back. The heartbeat of every agent.', session: 's01' },
  { term: 'Harness', definition: 'The code that wraps the LLM — tool execution, context management, safety checks. The model decides; the harness executes.', session: 's01' },
  { term: 'Tool Schema', definition: 'A JSON object describing a tool\'s name, description, and input parameters. The LLM reads schemas to decide which tool to call and with what arguments.', session: 's02' },
  { term: 'Dispatch Map', definition: 'A dictionary mapping tool names to handler functions: {"bash": run_bash, "read_file": run_read}. One lookup replaces a chain of if/elif.', session: 's02' },
  { term: 'Path Sandboxing', definition: 'Resolving file paths against an allowed root directory to prevent the agent from reading or writing outside its workspace.', session: 's02' },
  { term: 'TodoManager', definition: 'A planning tool that tracks tasks with statuses (pending, in_progress, completed). Enforces one-at-a-time focus and injects nag reminders.', session: 's03' },
  { term: 'Subagent', definition: 'A disposable child agent spawned with a fresh context for a single subtask. Returns a summary and dies — no context pollution.', session: 's04' },
  { term: 'Skill Loading', definition: 'Two-layer pattern: cheap descriptions in the system prompt, expensive full content loaded on-demand. Keeps the context lean.', session: 's05' },
  { term: 'Context Compaction', definition: 'Progressive compression of conversation history. Micro: trim old tool results. Mid: summarize at 50k tokens. Hard: LLM-written summary at 80k tokens.', session: 's06' },
  { term: 'Micro Compaction', definition: 'Replacing tool results older than 3 turns with one-line placeholders like "[Previous: used read_file]". Silent, runs every turn.', session: 's06' },
  { term: 'Hard Compaction', definition: 'Asking the LLM to write a dense summary of the entire conversation, then replacing all history with that summary. Last resort.', session: 's06' },
  { term: 'Task Graph', definition: 'A directed acyclic graph (DAG) of tasks with dependencies (blockedBy). Persisted as JSON files on disk, surviving crashes and context compression.', session: 's07' },
  { term: 'Background Task', definition: 'A subprocess running in a thread while the agent continues thinking. Results are injected via a shared queue before each LLM call.', session: 's08' },
  { term: 'Agent Mailbox', definition: 'An append-only JSONL file (e.g., .team/inbox/alice.jsonl) for inter-agent communication. Write by appending; read by draining (read + truncate).', session: 's09' },
  { term: 'Drain Pattern', definition: 'Read all messages from a mailbox, then truncate the file. Messages are consumed once and not replayed on the next poll.', session: 's09' },
  { term: 'Team Roster', definition: 'A JSON config listing all teammates with names, roles, and lifecycle statuses (IDLE, WORKING, SHUTDOWN).', session: 's09' },
  { term: 'Request-Response Protocol', definition: 'A structured mailbox message format with unique IDs, enabling agents to match responses to requests.', session: 's10' },
  { term: 'Autonomous Claiming', definition: 'Agents scan the task board independently and claim ready tasks without being told. Self-organizing teamwork.', session: 's11' },
  { term: 'Worktree', definition: 'A separate git working directory linked to the same repository. Each worktree is on its own branch, providing filesystem isolation for parallel agent work.', session: 's12' },
  { term: 'Eval Case', definition: 'A structured test scenario for an agent: a prompt, resource limits, and a checker function that scores the outcome.', session: 's13' },
  { term: 'Scoring Rubric', definition: 'Criteria that define agent success: pass/fail checks, partial credit, efficiency metrics. Turns subjective quality into numbers.', session: 's13' },
  { term: 'Guardrail', definition: 'A permission layer that checks every tool call before execution. Can auto-approve, require human approval, or deny outright.', session: 's14' },
  { term: 'Human-in-the-Loop', definition: 'Pausing the agent before dangerous actions to ask the user for confirmation. The harness intercepts the tool call and waits for approval.', session: 's14' },
  { term: 'Cost Cap', definition: 'A hard ceiling on total token spending. Once exceeded, all tool calls are blocked regardless of other permissions.', session: 's14' },
  { term: 'Agent Trace', definition: 'A JSONL recording of every event in an agent session: LLM calls, tool executions, errors, compressions. The flight recorder for debugging.', session: 's15' },
  { term: 'Replay Debugging', definition: 'Re-running an agent using recorded LLM responses instead of live API calls. Deterministic reproduction of bugs, zero token cost.', session: 's15' },
  { term: 'Model Routing', definition: 'Using different models for different tasks: cheap models (Haiku) for simple decisions, powerful models (Opus/Sonnet) for complex reasoning.', session: 's16' },
  { term: 'Exponential Backoff', definition: 'Retry strategy where wait time doubles between attempts (1s, 2s, 4s, 8s). Prevents hammering a failing API.', session: 's16' },
];
---

<Base title={ui['session.glossary']}>
  <Header />
  <main class="session-page glossary-page">
    <div class="container" style="max-width: var(--max-width);">
      <h1 style="margin-block-end: 0.5rem;">{ui['session.glossary']}</h1>
      <p style="color: var(--text-muted); margin-block-end: 2rem; font-size: 0.9rem;">
        Key terms and concepts from the Agent Harness Engineering course, in order of appearance.
      </p>
      <div class="glossary-grid">
        {terms.map(t => (
          <div class="glossary-term">
            <h3>
              {t.term}
              <a href={`/en/${t.session === 's01' ? 's01-the-agent-loop' : t.session === 's02' ? 's02-tool-use' : t.session === 's03' ? 's03-todo-write' : t.session === 's04' ? 's04-subagent' : t.session === 's05' ? 's05-skill-loading' : t.session === 's06' ? 's06-context-compact' : t.session === 's07' ? 's07-task-system' : t.session === 's08' ? 's08-background-tasks' : t.session === 's09' ? 's09-agent-teams' : t.session === 's10' ? 's10-team-protocols' : t.session === 's11' ? 's11-autonomous-agents' : t.session === 's12' ? 's12-worktree-task-isolation' : t.session === 's13' ? 's13-agent-evals' : t.session === 's14' ? 's14-guardrails' : t.session === 's15' ? 's15-observability' : 's16-shipping-to-production'}`} class="glossary-session">{t.session}</a>
            </h3>
            <p>{t.definition}</p>
          </div>
        ))}
      </div>
    </div>
  </main>
  <Footer />
</Base>
