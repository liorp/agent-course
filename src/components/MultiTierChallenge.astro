---
import { getLangFromUrl, getUI } from '@/i18n/ui';

interface ChallengeItem {
  tier: 'warmup' | 'build' | 'stretch';
  text: string;
  hint?: string;
}

interface Props {
  challenges: ChallengeItem[];
}

const { challenges } = Astro.props;
const locale = getLangFromUrl(Astro.url);
const ui = getUI(locale);

const tierConfig = {
  warmup: { icon: '🔥', labelKey: 'session.challenge.warmup' as const, time: '~5 min', cssClass: 'tier-warmup' },
  build:  { icon: '🔨', labelKey: 'session.challenge.build' as const, time: '~20 min', cssClass: 'tier-build' },
  stretch:{ icon: '🚀', labelKey: 'session.challenge.stretch' as const, time: '~45 min', cssClass: 'tier-stretch' },
};

/** Convert backtick-wrapped text to <code> HTML */
function inlineCode(s: string): string {
  return s.replace(/`([^`]+)`/g, '<code>$1</code>');
}
---

<div class="challenges-container">
  <div class="challenges-header">
    <span class="challenges-icon">🧪</span>
    <span class="challenges-label">{ui['session.challenge']}</span>
  </div>
  <div class="challenges-tiers">
    {challenges.map((c) => {
      const config = tierConfig[c.tier];
      return (
        <div class={`challenge-tier ${config.cssClass}`}>
          <div class="tier-header">
            <span class="tier-icon">{config.icon}</span>
            <span class="tier-label">{ui[config.labelKey]}</span>
            <span class="tier-time">{config.time}</span>
          </div>
          <p class="tier-text" set:html={inlineCode(c.text)} />
          {c.hint && (
            <details class="tier-hint">
              <summary>{ui['session.hint']}</summary>
              <p set:html={inlineCode(c.hint)} />
            </details>
          )}
        </div>
      );
    })}
  </div>
</div>

<style>
  .challenges-container {
    background: linear-gradient(135deg, rgba(255, 204, 0, 0.05), rgba(255, 204, 0, 0.02));
    border: 1px solid rgba(255, 204, 0, 0.2);
    border-radius: 10px;
    padding: 1.25rem;
    margin-block: 2rem;
  }
  .challenges-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-block-end: 1rem;
  }
  .challenges-icon { font-size: 1.2rem; }
  .challenges-label {
    color: var(--accent);
    font-weight: 600;
    font-size: 0.9rem;
  }
  .challenges-tiers {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .challenge-tier {
    padding: 1rem;
    border-radius: 8px;
    border-inline-start: 3px solid var(--border);
  }
  .tier-warmup { border-inline-start-color: #4ade80; background: rgba(74, 222, 128, 0.04); }
  .tier-build  { border-inline-start-color: #60a5fa; background: rgba(96, 165, 250, 0.04); }
  .tier-stretch { border-inline-start-color: #c084fc; background: rgba(192, 132, 252, 0.04); }
  .tier-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-block-end: 0.5rem;
  }
  .tier-label {
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--text-primary);
  }
  .tier-time {
    color: var(--text-muted);
    font-size: 0.75rem;
    margin-inline-start: auto;
  }
  .tier-text {
    color: var(--text-body);
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0;
  }
  .tier-hint { margin-block-start: 0.5rem; }
  .tier-hint summary {
    color: var(--text-muted);
    font-size: 0.8rem;
    cursor: pointer;
    list-style: none;
  }
  .tier-hint summary::before { content: '💡 '; }
  .tier-hint p {
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-block-start: 0.35rem;
  }
</style>
