---
import { getLangFromUrl, getUI } from '@/i18n/ui';
const locale = getLangFromUrl(Astro.url);
const ui = getUI(locale);
---

<section class="email-capture">
  <div class="email-inner">
    <h3 class="email-title">{ui['email.title']}</h3>
    <p class="email-subtitle">{ui['email.subtitle']}</p>
    <a href="https://liorp.substack.com/subscribe" target="_blank" rel="noopener" class="email-btn">{ui['email.button']}</a>
  </div>
</section>

<style>
  .email-capture {
    margin-block: 3rem;
    padding: 2rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    text-align: center;
  }
  .email-title {
    color: var(--text-primary);
    margin-block-end: 0.25rem;
  }
  .email-subtitle {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-block-end: 1rem;
  }
  .email-btn {
    display: inline-block;
    padding: 0.6rem 1.5rem;
    background: var(--accent);
    color: var(--bg-primary);
    border: none;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    transition: background 0.2s;
    font-family: var(--font-body);
    text-decoration: none;
  }
  .email-btn:hover { background: var(--accent-hover); color: var(--bg-primary); }
</style>

