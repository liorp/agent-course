---
import { getLangFromUrl, getUI } from '@/i18n/ui';
const locale = getLangFromUrl(Astro.url);
const ui = getUI(locale);
---

<section class="email-capture">
  <div class="email-inner">
    <h3 class="email-title">{ui['email.title']}</h3>
    <p class="email-subtitle">{ui['email.subtitle']}</p>
    <div class="substack-embed">
      <iframe
        src="https://liorp.substack.com/embed"
        width="480"
        height="150"
        style="border: none; background: transparent;"
        frameborder="0"
        scrolling="no"
        loading="lazy"
      ></iframe>
    </div>
  </div>
</section>

<style>
  .email-capture {
    margin-block: 3rem;
    padding: 2rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    text-align: center;
  }
  .email-title {
    color: var(--text-primary);
    margin-block-end: 0.25rem;
  }
  .email-subtitle {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-block-end: 1rem;
  }
  .substack-embed {
    display: flex;
    justify-content: center;
  }
  .substack-embed iframe {
    max-width: 100%;
    border-radius: 8px;
  }
</style>
