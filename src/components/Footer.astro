---
import AdSlot from './AdSlot.astro';
import EmailCapture from './EmailCapture.astro';
import { getLangFromUrl, getUI } from '@/i18n/ui';

const locale = getLangFromUrl(Astro.url);
const ui = getUI(locale);
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <EmailCapture />
  <AdSlot format="banner" slot="4632823302" />
  <div class="footer-inner container">
    <p class="footer-text">
      {ui['footer.basedOn']} <a href="https://github.com/shareAI-lab/learn-claude-code" target="_blank" rel="noopener">learn-claude-code</a> {ui['footer.by']} <a href="https://github.com/shareAI-lab/learn-claude-code/blob/main/LICENSE" target="_blank" rel="noopener">{ui['footer.license']}</a>
    </p>
    <p class="footer-copyright">&copy; {currentYear} Lior Polak</p>
    <p class="footer-motto">{ui['footer.motto']}</p>
    <p class="footer-report">
      <a href="https://github.com/liorp/agent-course/issues/new?labels=fix" target="_blank" rel="noopener">{ui['footer.reportIssue']}</a>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    border-block-start: 1px solid var(--border);
    padding-block: 2rem;
    margin-block-start: 4rem;
  }
  .footer-inner {
    text-align: center;
  }
  .footer-text {
    color: var(--text-muted);
    font-size: 0.85rem;
  }
  .footer-copyright {
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-block-start: 0.25rem;
  }
  .footer-motto {
    color: var(--text-muted);
    font-size: 0.8rem;
    font-style: italic;
    opacity: 0.7;
    margin-block-start: 0.5rem;
  }
  .footer-report {
    margin-block-start: 0.75rem;
    font-size: 0.8rem;
  }
  .footer-report a {
    color: var(--text-muted);
    opacity: 0.6;
    transition: opacity 0.2s;
  }
  .footer-report a:hover {
    opacity: 1;
    color: var(--accent);
  }
</style>
